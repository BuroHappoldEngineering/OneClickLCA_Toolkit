{
  "openapi": "3.0.1",
  "info": {
    "title": "Calculation Results API",
    "description": "Calculation Results API by One Click LCA provides access to project results. It provides one endpoint to retrieve projects with associated designs and tools, and another endpoint to retrieve actual results per design-tool combination.\n\n\n\nTo access this API you need to receive an access token from One Click LCA. Additional support documentation is available on request from One Click LCA.",
    "termsOfService": "https://oneclicklca.com/service-terms",
    "contact": {
      "name": "One Click LCA",
      "url": "https://www.oneclicklca.com/",
      "email": "sales@oneclicklca.com"
    },
    "version": "1.0.4"
  },
  "servers": [
    {
      "url": "https://oneclicklcaapp.com/results-api"
    }
  ],
  "tags": [
    {
      "name": "Calculation Results",
      "description": "APIs to handle calculation results"
    },
    {
      "name": "Projects",
      "description": "These API(s) are used to handle project related operations"
    }
  ],
  "paths": {
    "/projects": {
      "get": {
        "tags": [
          "Projects"
        ],
        "summary": "Get list of Projects with associated designs",
        "description": "Get list of Projects with associated designs by page for a user who was added as manager, modifier or readonly user. It doesn't return the deleted designs. ",
        "operationId": "getProjects",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page Number: 1, 2, 3... If not provided, defaults to 1",
            "required": true,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of Records per Page. If not provided, defaults to value: 20 Maximum value allowed is: 100",
            "required": true,
            "schema": {
              "maximum": 100,
              "type": "string"
            }
          },
          {
            "name": "lastUpdatedAfter",
            "in": "query",
            "description": "The response will include only project-level information updated after this date (UTC). To retrieve design-level information or new values, fetch all data without this filter and use the lastUpdated field to identify the most recent entries.Supported Date formats: *yyyy-MM-dd*, *M/d/yy* or *dd.MM.yyyy*",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2024-08-30"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Found the project(s)",
            "headers": {
              "ocl-request-id": {
                "description": "Unique request identifier assigned to each request for request tracing purpose.",
                "style": "simple",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectListResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden. You do not have permission to access the resource.",
            "headers": {
              "ocl-request-id": {
                "description": "Unique request identifier assigned to each request for request tracing purpose.",
                "style": "simple",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                },
                "example": {
                  "error": [
                    {
                      "code": "RESULTS_8003",
                      "level": "ERROR",
                      "message": "You don't have access to the requested resource",
                      "description": ""
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Resource not found. The requested resource is not found.",
            "headers": {
              "ocl-request-id": {
                "description": "Unique request identifier assigned to each request for request tracing purpose.",
                "style": "simple",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                },
                "example": {
                  "error": [
                    {
                      "code": "RESULTS_8004",
                      "level": "ERROR",
                      "message": "Resource not found",
                      "description": ""
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error. The server encountered an unexpected condition.",
            "headers": {
              "ocl-request-id": {
                "description": "Unique request identifier assigned to each request for request tracing purpose.",
                "style": "simple",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                },
                "example": {
                  "error": [
                    {
                      "code": "RESULTS_9999",
                      "level": "ERROR",
                      "message": "Some technical exception occurred",
                      "description": "Server is unable to process the request due to XYZ"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request. The request sent to the server is invalid or corrupted. The request parameters could be malformed or HTTP headers could be invalid.",
            "headers": {
              "ocl-request-id": {
                "description": "Unique request identifier assigned to each request for request tracing purpose.",
                "style": "simple",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                },
                "example": {
                  "error": [
                    {
                      "code": "RESULTS_8006",
                      "level": "ERROR",
                      "message": "Some attribute is invalid",
                      "description": ""
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. The access token in the request is invalid."
          }
        },
        "security": [
          {
            "bearer-token": []
          }
        ]
      }
    },
    "/calculation-results": {
      "get": {
        "tags": [
          "Calculation Results"
        ],
        "summary": "Get Calculation Results",
        "description": "Get list of Calculation Results with associated filters for design and tool identifier.",
        "operationId": "getAllCalculationResultsSynthetic",
        "parameters": [
          {
            "name": "designId",
            "in": "query",
            "description": "Mandatory Unique identifier for the design.",
            "required": true,
            "schema": {
              "maxLength": 24,
              "minLength": 24,
              "pattern": "^[a-zA-Z0-9]*$",
              "type": "string",
              "description": "Mandatory Unique identifier for the design.",
              "example": "643c13575b614a2bfdbcbb03"
            }
          },
          {
            "name": "toolId",
            "in": "query",
            "description": "Mandatory Identifier for the tool used in the calculation",
            "required": true,
            "schema": {
              "maxLength": 100,
              "minLength": 2,
              "type": "string",
              "description": "Mandatory Identifier for the tool used in the calculation",
              "example": "flexibleEPDTool"
            }
          },
          {
            "name": "showAllCategoriesForTool",
            "in": "query",
            "description": "Optional Flag to show all result categories for the tool. It is taken into account only when toolId is set. By default, result doesn't contain dummy categories (like fullBuildings) that are not shown on the result page.",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Optional Flag to show all result categories for the tool. It is taken into account only when toolId is set. By default, result doesn't contain dummy categories (like fullBuildings) that are not shown on the result page.",
              "default": false
            }
          }
        ],
        "responses": {
          "403": {
            "description": "Forbidden. You do not have permission to access the resource.",
            "headers": {
              "ocl-request-id": {
                "description": "Unique request identifier assigned to each request for request tracing purpose.",
                "style": "simple",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
